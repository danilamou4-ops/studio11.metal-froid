# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co   # Project URL from Supabase dashboard
NEXT_PUBLIC_SUPABASE_ANON_KEY=                       # Anon/public key (safe to expose client-side)
SUPABASE_SERVICE_ROLE_KEY=                           # Service role key (server-side only — never expose)

# App
NEXT_PUBLIC_SITE_URL=                                # Production URL (https://your-app.vercel.app)

# External APIs
LASTFM_API_KEY=                                      # Last.fm API key for curator/track enrichment
